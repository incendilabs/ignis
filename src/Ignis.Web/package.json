{
  "name": "ignis-web",
  "private": true,
  "type": "module",
  "imports": {
    "#app/*": "./app/*"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "npm run paraglide:compile && react-router typegen && eslint .",
    "paraglide:compile": "paraglide-js compile --project ./app/i18n/project.inlang --outdir ./app/i18n/paraglide --emit-ts-declarations --strategy url cookie preferredLanguage baseLocale",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run paraglide:compile && react-router typegen && tsc"
  },
  "dependencies": {
    "@eventuras/fides-auth": "^0.8.0",
    "@eventuras/logger": "^0.8.1",
    "@eventuras/ratio-ui": "^2.6.0",
    "@react-router/node": "7.16.0",
    "@react-router/serve": "7.16.0",
    "@tanstack/react-table": "^8.21.3",
    "isbot": "^5.1.40",
    "react": "^19.2.7",
    "react-aria-components": "^1.18.0",
    "react-dom": "^19.2.7",
    "react-router": "7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.18.2",
    "@inlang/plugin-m-function-matcher": "^2.2.6",
    "@inlang/plugin-message-format": "^4.4.0",
    "@react-router/dev": "7.16.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
