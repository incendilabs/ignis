# Copy to .env and fill in. .env is gitignored.

# 32 bytes of hex used to encrypt the session cookie.
# Generate with: openssl rand -hex 32
IGNIS_WEB_SESSION_SECRET=

# OAuth client registered in Ignis.Auth
IGNIS_WEB_CLIENT_ID=ignis-web
IGNIS_WEB_CLIENT_SECRET=

# Auth server issuer. Normally the API URL.
IGNIS_AUTH_ISSUER=

# Public URL where the web app is served. Used to build absolute URIs
# (e.g. OAuth redirect URIs). Scheme + host[:port], no path, no trailing slash.
# Must match a RedirectUri on the ignis-web client.
IGNIS_WEB_APP_URL=http://localhost:5202

# Feature flags. Set to "true" to expose a feature.
IGNIS_WEB_FEATURES_AUTH=true
