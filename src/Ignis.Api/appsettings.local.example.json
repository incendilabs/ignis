{
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "Spark": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "StoreSettings": {
    "ConnectionString": "mongodb://localhost:27017/ignis_dev"
  },
  "FeatureManagement": {
    "AllowClearStore": true
  },
  "AuthSettings": {
    "Issuer": "",
    "ExternalProviders": [
      {
        "Name": "GitHub",
        "Type": "GitHub",
        "ClientId": "<github-oauth-app-client-id>",
        "ClientSecret": ""
      }
    ],
    "Clients": [
      {
        "ClientId": "ignis-web",
        "ClientSecret": "",
        "DisplayName": "Ignis Web (local dev)",
        "AllowedGrantTypes": ["authorization_code"],
        "RedirectUris": ["http://localhost:5202/auth/callback"],
        "PostLogoutRedirectUris": ["http://localhost:5202"],
        "AllowedScopes": ["openid", "profile", "email", "operations.read"]
      }
    ],
    "Users": [
      {
        "Subject": "github:<your-github-numeric-id>",
        "Scopes": ["openid", "profile", "email", "operations.read"]
      }
    ]
  }
}
