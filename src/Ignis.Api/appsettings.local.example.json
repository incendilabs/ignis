{
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "Spark": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "StoreSettings": {
    "ConnectionString": "mongodb://localhost:27017/ignis_dev"
  },
  "FeatureManagement": {
    "AllowClearStore": true,
    "AllowImport": true
  },
  "ForwardedHeaders": {
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "AuthSettings": {
    "Issuer": "https://localhost:5201",
    "ExternalProviders": [
      {
        "Name": "GitHub",
        "Type": "GitHub",
        "ClientId": "<github-oauth-app-client-id>",
        "ClientSecret": ""
      }
    ],
    "Clients": [
      {
        "ClientId": "ignis-web",
        "ClientSecret": "",
        "DisplayName": "Ignis Web (local dev)",
        "AllowedGrantTypes": ["authorization_code"],
        "RedirectUris": ["https://localhost:5202/auth/callback"],
        "PostLogoutRedirectUris": ["https://localhost:5202"],
        "AllowedScopes": [
          "openid",
          "profile",
          "email",
          "operations.read",
          "operations.import",
          "maintenance/database.destructive",
          "maintenance/database.write"
        ]
      }
    ],
    "Users": [
      {
        "Subject": "github:<your-github-numeric-id>",
        "Scopes": [
          "openid",
          "profile",
          "email",
          "operations.read",
          "operations.import",
          "maintenance/database.destructive",
          "maintenance/database.write"
        ]
      }
    ]
  }
}
